    "node-fetch": "^3.3.2",
    "turndown": "^7.1.3"
  },
  "devDependencies": {
    "@types/figlet": "^1.5.8",
    "@types/gradient-string": "^1.1.5",
    "@types/node": "^20.11.0",
    "@types/turndown": "^5.0.4",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
